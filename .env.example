# Copy to .env and fill in real values. Never commit the real .env.

# --- Backend ---
BACKEND_PORT=8000
# Absolute path to the CUPS socket/directory on the host, mounted
# read-write into the backend container at the same path.
CUPS_HOST=/var/run/cups

# --- Frontend (baked in at build time via Vite) ---
VITE_API_BASE_URL=http://localhost:8000/api
VITE_CONTACT_NAME=
VITE_CONTACT_NUMBER=

# --- Postgres ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
