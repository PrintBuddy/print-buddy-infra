# Copy to .env and fill in real values. Never commit the real .env.
# This one file is shared across backend/bot/frontend via env_file — same
# pattern the original untracked deploy used.

# --- Backend: app ---
PROJECT_NAME=PrintBuddy
VERSION=1.0.0
ENVIRONMENT=production
URL=10.0.10.3
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000/api/
API_BASE_URL=http://backend:8000/api
CORS_ORIGINS=http://10.0.10.3
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE_MB=50
PRINTER_MARKERS_DB=/app/printer_markers.db
CUPS_HOST=/var/run/cups/cups.sock

# --- Backend: auth/secrets ---
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXP_MIN=60
PWD_RESET_SALT=
PWD_RESET_URL=http://10.0.10.3/password-reset
PWD_RESET_TIME_MIN=30
# Shared with the bot — must be the exact same value in both places.
TELEGRAM_SECRET=

# --- Backend: database (Postgres runs as its own separate container —
# see docker-compose.yml's networks section — these just need to match
# whatever that container's actual credentials are) ---
DB_SCHEME=postgresql+psycopg
DB_HOSTNAME=postgres
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- Backend: mail ---
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=PrintBuddy
MAIL_PORT=587
MAIL_SERVER=

# --- Backend: optional error tracking (Sentry). Leave unset to disable. ---
# SENTRY_DSN=

# --- Bot ---
TELEGRAM_TOKEN=
# API_BASE_URL above is reused by the bot too.

# --- Frontend (baked in at CI *build* time via GitHub repo variables on
# the frontend repo, NOT read from this file at runtime — listed here only
# so you know they need to be set somewhere) ---
# VITE_API_BASE_URL=http://10.0.10.3:8000/api
# VITE_CONTACT_NAME=
# VITE_CONTACT_NUMBER=

# --- Optional: pin a service to a specific previously-built image instead
# of :latest (see rollback.sh). Leave unset in normal operation. ---
# BACKEND_TAG=
# BOT_TAG=
# FRONTEND_TAG=
